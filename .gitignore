# Rust
/target/
**/target/
**/*.rs.bk
# Note: Cargo.lock is committed for binary crates (reproducible builds).
# Only gitignore Cargo.lock in library crates.

# Byproducts
*.log
*.tmp
*.swp
*.swo
*.bak
.DS_Store

# IDEs
.idea/
.vscode/
*.iml

# Test & coverage
coverage/
*.profraw

# Claude Code
.plans/
session-logs/

# e2e credentials
e2e/.env
e2e/.env.snowflake

# Python build artifacts (e2e/ is installed with pip install -e)
e2e/src/**/__pycache__/
e2e/src/**/*.egg-info/
e2e/**/*.pyc

# Misc
*.old
