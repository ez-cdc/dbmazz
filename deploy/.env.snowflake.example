# =============================================================================
# dbmazz CDC Daemon — Snowflake Sink Credentials
# =============================================================================
# Copy to .env.snowflake and fill in your values:
#   cp deploy/.env.snowflake.example deploy/.env.snowflake
#
# Required for: docker compose --profile snowflake up -d
# Also sourced by: deploy/test-sink.sh snowflake
#
# Free 30-day trial: https://signup.snowflake.com

# --- Required ---
SINK_SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SINK_SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SINK_DATABASE=DBMAZZ_TEST
SINK_USER=your_username
SINK_PASSWORD=your_password

# --- Optional ---
# SINK_URL=                                      # Auto-derived from account
# SINK_SCHEMA=PUBLIC                             # Target schema
# SINK_SNOWFLAKE_ROLE=                           # Snowflake role

# --- Auth: JWT key-pair (alternative to password) ---
# SINK_SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SINK_SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# --- Test tuning (low-latency flush for E2E verification) ---
SINK_SNOWFLAKE_FLUSH_FILES=1
SINK_SNOWFLAKE_SOFT_DELETE=false
SINK_SNOWFLAKE_MERGE_INTERVAL_MS=2000
